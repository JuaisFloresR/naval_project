generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ship {
  id          String     @id @default(uuid())
  name        String
  type        String
  length      Decimal   
  width       Decimal   
  height      Decimal    
  description String
  status      ShipStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())

  // Relación activa
  rows        RowShip[]

  // Relación comentada (para evitar error de validación)
  // parts Part[]
}

enum ShipStatus {
  ACTIVE
  INACTIVE
  RETIRED
  UNDER_REPAIR
}

model RowShip {
  id           String   @id @default(uuid())
  draft        Decimal  // (m)
  displacement Decimal  // (TM)
  wl_length    Decimal  // (m)
  wl_beam      Decimal  // (m)
  wetted_area  Decimal  // (m2)
  waterpl_area Decimal  // (m2)
  cp           Decimal  // (-)
  cb           Decimal  // (-)
  cm           Decimal  // (-)
  cwp          Decimal  // (-)
  lcb          Decimal  // (m)
  lcf          Decimal  // (m)
  kb           Decimal  // (m)
  bmt          Decimal  // (m)
  bml          Decimal  // (m)
  gmt          Decimal  // (m)
  gml          Decimal  // (m)
  kmt          Decimal  // (m)
  kml          Decimal  // (m)
  tpc          Decimal  // (TM/cm)
  mtc          Decimal  // TM-m
  rm_at_1deg   Decimal  // TM-m

  createdAt    DateTime @default(now())
  shipId       String
  ship         Ship     @relation(fields: [shipId], references: [id])

  @@index([shipId])
}

